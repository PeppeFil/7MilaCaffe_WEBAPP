# Dominio pubblico che punta alla VPS (senza https://)
DOMAIN=app.example.it

# Immagine pubblicata automaticamente da GitHub Actions.
APP_IMAGE=ghcr.io/peppefil/7milacaffe-webapp:latest

# Genera un valore casuale con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret

# Copia la Session pooler connection string dal pulsante Connect di Supabase.
# Aggiungi ?sslmode=require alla fine.
DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Necessarie solo per il primo deploy. Rimuovile dal file dopo che il comando
# automatico ha creato l'amministratore iniziale.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.it
ADMIN_PASSWORD=replace-with-a-unique-long-password
